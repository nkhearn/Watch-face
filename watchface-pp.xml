<?xml version="1.0"?>
<WatchFace height="450" width="450">
    <Define>
        COLORS = {
            "red": "#FFD00000",
            "gold": "#FFE7E7A5",
            "background": "#FF000000",
            "grey": "#FF737373"
        }
    </Define>

    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:10:46" />

    <Scene backgroundColor="{COLORS['background']}">
        <!-- Top: Date -->
        <PartText x="0" y="20" width="450" height="60">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="36" color="{COLORS['gold']}">
                    [DAY_S] [DAY_1_31]
                </Font>
            </Text>
        </PartText>

        <!-- Middle: Time -->
        <PartText x="0" y="80" width="450" height="120">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="100" color="{COLORS['red']}">
                    [HOUR_0_23_Z]:[MIN_Z]
                </Font>
            </Text>
        </PartText>

        <!-- AM/PM and Seconds -->
        <PartText x="20" y="110" width="100" height="40">
            <Text align="LEFT">
                <Font family="SYNC_TO_DEVICE" size="24" color="{COLORS['red']}">
                    [AMPM]
                </Font>
            </Text>
        </PartText>
        <PartText x="330" y="110" width="100" height="40">
            <Text align="RIGHT">
                <Font family="SYNC_TO_DEVICE" size="24" color="{COLORS['red']}">
                    [SEC_Z]
                </Font>
            </Text>
        </PartText>

        <!-- Bottom: Doom Guy and Complications -->

        <!-- Left: Battery -->
        <Group x="0" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" color="{COLORS['grey']}">BAT</Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="{COLORS['red']}">[BATTERY_PERCENT]</Font>
                </Text>
            </PartText>
        </Group>

        <!-- Center: Doom Guy Face -->
        <Group x="150" y="200" width="150" height="250">
            <!-- 80-100% -->
            <Condition>
                <Expressions>
                    <Expression name="is_healthy">[BATTERY_PERCENT] >= 80</Expression>
                </Expressions>
                <Compare expression="is_healthy">
                    <PartImage x="0" y="20" width="150" height="150" resource="@drawable/doom_healthy" />
                </Compare>
            </Condition>
            <!-- 50-80% -->
            <Condition>
                <Expressions>
                    <Expression name="is_hurt">[BATTERY_PERCENT] >= 50 &amp;&amp; [BATTERY_PERCENT] &lt; 80</Expression>
                </Expressions>
                <Compare expression="is_hurt">
                    <PartImage x="0" y="20" width="150" height="150" resource="@drawable/doom_hurt" />
                </Compare>
            </Condition>
            <!-- 20-50% -->
            <Condition>
                <Expressions>
                    <Expression name="is_dying">[BATTERY_PERCENT] >= 20 &amp;&amp; [BATTERY_PERCENT] &lt; 50</Expression>
                </Expressions>
                <Compare expression="is_dying">
                    <PartImage x="0" y="20" width="150" height="150" resource="@drawable/doom_dying" />
                </Compare>
            </Condition>
            <!-- 0-20% -->
            <Condition>
                <Expressions>
                    <Expression name="is_dead">[BATTERY_PERCENT] &lt; 20</Expression>
                </Expressions>
                <Compare expression="is_dead">
                    <PartImage x="0" y="20" width="150" height="150" resource="@drawable/doom_dead" />
                </Compare>
            </Condition>
        </Group>

        <!-- Right: Heart Rate -->
        <Group x="300" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" color="{COLORS['grey']}">BPM</Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="{COLORS['red']}">[HEART_RATE]</Font>
                </Text>
            </PartText>
        </Group>

    </Scene>
</WatchFace>
