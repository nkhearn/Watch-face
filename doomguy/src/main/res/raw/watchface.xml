<WatchFace height="450" width="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:10:46"/>

    <Resources>
        <Bitmap id="doom_healthy" resource="@drawable/doom_healthy"/>
        <Bitmap id="doom_hurt" resource="@drawable/doom_hurt"/>
        <Bitmap id="doom_dying" resource="@drawable/doom_dying"/>
        <Bitmap id="doom_dead" resource="@drawable/doom_dead"/>
    </Resources>

    <Scene backgroundColor="#FF000000">

        <PartText x="0" y="20" width="450" height="60">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="36" color="#FFE7E7A5">
                    [DAY_S] [DAY_1_31]
                </Font>
            </Text>
        </PartText>


        <PartText x="0" y="80" width="450" height="120">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="100" color="#FFD00000">
                    [HOUR_0_23_Z]:[MIN_Z]
                </Font>
            </Text>
        </PartText>


        <PartText x="20" y="110" width="100" height="40">
            <Text align="LEFT">
                <Font family="SYNC_TO_DEVICE" size="24" color="#FFD00000">
                    [AMPM]
                </Font>
            </Text>
        </PartText>
        <PartText x="330" y="110" width="100" height="40">
            <Text align="RIGHT">
                <Font family="SYNC_TO_DEVICE" size="24" color="#FFD00000">
                    [SEC_Z]
                </Font>
            </Text>
        </PartText>




        <Group x="0" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" color="#FF737373">BAT</Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="#FFD00000">[BATTERY_PERCENT]</Font>
                </Text>
            </PartText>
        </Group>


        <Group x="150" y="200" width="150" height="250">

            <Condition>
                <Expressions>
                    <Expression name="is_healthy">[BATTERY_PERCENT] &gt;= 80</Expression>
                </Expressions>
                <Compare expression="is_healthy">
                    <PartImage x="0" y="20" width="150" height="150" resource="doom_healthy"/>
                </Compare>
            </Condition>

            <Condition>
                <Expressions>
                    <Expression name="is_hurt">[BATTERY_PERCENT] &gt;= 50 &amp;&amp; [BATTERY_PERCENT] &lt; 80</Expression>
                </Expressions>
                <Compare expression="is_hurt">
                    <PartImage x="0" y="20" width="150" height="150" resource="doom_hurt"/>
                </Compare>
            </Condition>

            <Condition>
                <Expressions>
                    <Expression name="is_dying">[BATTERY_PERCENT] &gt;= 20 &amp;&amp; [BATTERY_PERCENT] &lt; 50</Expression>
                </Expressions>
                <Compare expression="is_dying">
                    <PartImage x="0" y="20" width="150" height="150" resource="doom_dying"/>
                </Compare>
            </Condition>

            <Condition>
                <Expressions>
                    <Expression name="is_dead">[BATTERY_PERCENT] &lt; 20</Expression>
                </Expressions>
                <Compare expression="is_dead">
                    <PartImage x="0" y="20" width="150" height="150" resource="doom_dead"/>
                </Compare>
            </Condition>
        </Group>


        <Group x="300" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" color="#FF737373">BPM</Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="#FFD00000">[HEART_RATE]</Font>
                </Text>
            </PartText>
        </Group>

    </Scene>
</WatchFace>