<WatchFace height="450" width="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:10:46" />

    <Resources>
        <Bitmap id="doom_healthy" resource="@drawable/doom_healthy" />
        <Bitmap id="doom_hurt" resource="@drawable/doom_hurt" />
        <Bitmap id="doom_dying" resource="@drawable/doom_dying" />
        <Bitmap id="doom_dead" resource="@drawable/doom_dead" />
    </Resources>

    <Scene backgroundColor="#FF000000">

        <PartText x="0" y="20" width="450" height="60">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="36" color="#FFE7E7A5">
                    <Template>%s %d<Parameter expression="[DAY_OF_WEEK_S]" /><Parameter expression="[DAY]" /></Template>
                </Font>
            </Text>
        </PartText>

        <DigitalClock x="0" y="80" width="450" height="120">
            <TimeText x="0" y="0" width="450" height="120" format="hh:mm" align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="100" weight="BOLD" color="#FFD00000" />
            </TimeText>
        </DigitalClock>

        <DigitalClock x="20" y="110" width="100" height="40">
            <TimeText x="0" y="0" width="100" height="40" format="a" align="START">
                <Font family="SYNC_TO_DEVICE" size="24" weight="BOLD" color="#FFD00000" />
            </TimeText>
        </DigitalClock>

        
        
            <!-- ================= LEFT BACKGROUND PANEL (BATTERY) ================= -->
        <PartDraw x="0" y="200" width="150" height="250">
            <!-- 1. Base Slate Gray (The underlying stone) -->
            <Rectangle x="0" y="0" width="150" height="250">
                <Fill color="#FF5A5A5A" />
            </Rectangle>

            <!-- 2. Heavy Top-Left Grime Stain (Large irregular dark patch) -->
            <Rectangle x="0" y="0" width="95" height="110">
                <Fill color="#FF3A3A3A" />
            </Rectangle>
            <Rectangle x="0" y="0" width="50" height="65">
                <Fill color="#FF282828" />
            </Rectangle>

            <!-- 3. Creeping Bottom-Right Mud/Shadow Stain -->
            <Rectangle x="35" y="150" width="115" height="100">
                <Fill color="#FF333333" />
            </Rectangle>
            <Rectangle x="75" y="195" width="75" height="55">
                <Fill color="#FF1F2120" />
            </Rectangle>

            <!-- 4. Mid-panel Weathered Discoloration -->
            <Rectangle x="0" y="130" width="60" height="40">
                <Fill color="#FF444444" />
            </Rectangle>

            <!-- 5. 3D Micro-Pitting (Classic 90s Engine Texture Grain) -->
            <!-- Pit Cluster A -->
            <Rectangle x="20" y="35" width="4" height="4"><Fill color="#FF1A1A1A"/></Rectangle>
            <Rectangle x="24" y="35" width="4" height="4"><Fill color="#FF8A8A8A"/></Rectangle>
            <Rectangle x="20" y="39" width="4" height="4"><Fill color="#FF1A1A1A"/></Rectangle>
            
            <!-- Pit Cluster B -->
            <Rectangle x="115" y="85" width="4" height="4"><Fill color="#FF1A1A1A"/></Rectangle>
            <Rectangle x="115" y="89" width="4" height="4"><Fill color="#FF8A8A8A"/></Rectangle>

            <!-- Pit Cluster C -->
            <Rectangle x="15" y="175" width="4" height="4"><Fill color="#FF1A1A1A"/></Rectangle>
            <Rectangle x="19" y="175" width="4" height="4"><Fill color="#FF8A8A8A"/></Rectangle>

            <!-- 6. Beveled Frame Outer Highlights (Gives the slab thickness) -->
            <Line startX="0" startY="1" endX="150" endY="1"><Stroke color="#FF8E8E8E" thickness="2"/></Line>
            <Line startX="1" startY="0" endX="1" endY="250"><Stroke color="#FF8E8E8E" thickness="2"/></Line>
        </PartDraw>
        
        
        
        
        

        <PartDraw x="300" y="200" width="150" height="250">
            <Rectangle x="0" y="0" width="150" height="250">
                <Fill color="#FF737373" />
            </Rectangle>
        </PartDraw>


        <Group name="BatteryGroup" x="0" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" weight="BOLD" color="#FFC0C0C0">
                        <Shadow radius="2.0" color="#FF000000" offsetX="2.0" offsetY="2.0" />
                        <Template>BAT</Template>
                    </Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="#FFD00000">
                        <Template>%d%%<Parameter expression="[BATTERY_PERCENT]" /></Template>
                    </Font>
                </Text>
            </PartText>

            <PartDraw x="60" y="130" width="30" height="30">
                 <Line startX="15" startY="0" endX="30" endY="15">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
                 <Line startX="30" startY="15" endX="15" endY="15">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
                 <Line startX="15" startY="15" endX="20" endY="30">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
                 <Line startX="20" startY="30" endX="5" endY="15">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
                 <Line startX="5" startY="15" endX="15" endY="15">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
                 <Line startX="15" startY="15" endX="15" endY="0">
                    <Stroke color="#FFE7E7A5" thickness="2" />
                 </Line>
            </PartDraw>
        </Group>


        <Group name="DoomGuyGroup" x="150" y="200" width="150" height="250">
            <Condition>
                <Expressions>
                    <Expression name="is_healthy">[BATTERY_PERCENT] &gt;= 80</Expression>
                    <Expression name="is_hurt">[BATTERY_PERCENT] &gt;= 50 &amp;&amp; [BATTERY_PERCENT] &lt; 80</Expression>
                    <Expression name="is_dying">[BATTERY_PERCENT] &gt;= 20 &amp;&amp; [BATTERY_PERCENT] &lt; 50</Expression>
                    <Expression name="is_dead">[BATTERY_PERCENT] &lt; 20</Expression>
                </Expressions>
                <Compare expression="is_healthy">
                    <PartImage x="6" y="26" width="138" height="138">
                        <Image resource="doom_healthy" />
                    </PartImage>
                </Compare>
                <Compare expression="is_hurt">
                    <PartImage x="6" y="26" width="138" height="138">
                        <Image resource="doom_hurt" />
                    </PartImage>
                </Compare>
                <Compare expression="is_dying">
                    <PartImage x="6" y="26" width="138" height="138">
                        <Image resource="doom_dying" />
                    </PartImage>
                </Compare>
                <Compare expression="is_dead">
                    <PartImage x="6" y="26" width="138" height="138">
                        <Image resource="doom_dead" />
                    </PartImage>
                </Compare>
            </Condition>
        </Group>
        


        <Group name="HeartRateGroup" x="300" y="200" width="150" height="250">
             <PartText x="0" y="20" width="150" height="40">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="24" weight="BOLD" color="#FFC0C0C0">
                        <Shadow radius="2.0" color="#FF000000" offsetX="2.0" offsetY="2.0" />
                        <Template>BPM</Template>
                    </Font>
                </Text>
            </PartText>
            <PartText x="0" y="60" width="150" height="60">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="48" color="#FFD00000">
                        <Template>%d<Parameter expression="[HEART_RATE]" /></Template>
                    </Font>
                </Text>
            </PartText>

            <PartDraw x="60" y="130" width="30" height="30">
                <Rectangle x="5" y="5" width="10" height="10">
                    <Fill color="#FFD00000" />
                </Rectangle>
                <Rectangle x="15" y="5" width="10" height="10">
                    <Fill color="#FFD00000" />
                </Rectangle>
                <Rectangle x="10" y="15" width="10" height="10">
                    <Fill color="#FFD00000" />
                </Rectangle>
            </PartDraw>
        </Group>

    </Scene>
</WatchFace>

